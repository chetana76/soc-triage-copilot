# Copy to .env and fill in. The pipeline runs WITHOUT these (offline fallback),
# but you need a Nebius key for the required live model call in the demo.

# --- Nebius Token Factory (required for the graded live call) ---
NEBIUS_API_KEY=
# Get the exact base URL + model string from your Nebius console / course:
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# --- Optional: live grounding ---
ENABLE_LIVE_NVD=0
NVD_API_KEY=

# --- Optional: tune the human-approval threshold ---
PAUSE_THRESHOLD=8.0

# --- Notifications ---
# Slack: create an Incoming Webhook for a channel and paste its URL here.
# If left blank, Slack posts are safely skipped and the pipeline still runs.
SLACK_WEBHOOK_URL=

# Email is written as a reviewable .eml DRAFT in OUTBOX_DIR (never auto-sent).
INCIDENT_EMAIL_TO=soc-oncall@example.com
INCIDENT_EMAIL_FROM=soc-copilot@example.com
OUTBOX_DIR=outbox

LANGCHAIN_TRACING_V2=true
